# ==============================================================================
# Vercel Deployment - Environment Variables
# ==============================================================================

# VITE_API_URL: The public URL of the Node.js backend on Render.
# MUST NOT end with a slash, MUST include /api at the end if the backend expects it.
# Example: https://onyx-server-xyz.onrender.com/api
# Default Local: /api  (uses Vite proxy)
VITE_API_URL=

# VITE_WS_URL: The WebSocket URL for the backend on Render.
# MUST start with wss:// instead of https://
# Example: wss://onyx-server-xyz.onrender.com/ws
# Default Local: ws://localhost:3001/ws (uses Vite proxy)
VITE_WS_URL=
