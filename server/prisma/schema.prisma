generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum Plan {
  FREE
  PRO
  TEAM
  ENTERPRISE
}

enum OrgRole {
  OWNER
  ADMIN
  VIEWER
}

// ---------------------------------------------------------------------------
// User
// ---------------------------------------------------------------------------
model User {
  id              String    @id @default(uuid())
  email           String    @unique
  name            String?   // user-set display name (optional)
  passwordHash    String?   // null for OAuth-only accounts (Google / GitHub)
  googleId        String?   @unique
  githubId        String?   @unique
  avatarUrl       String?
  createdAt       DateTime  @default(now())
  plan            Plan      @default(FREE)
  razorpaySubId   String?   @unique
  planExpiresAt   DateTime?

  testRuns        TestRun[]
  verifiedTargets VerifiedTarget[]
  orgMemberships  OrgMember[]

  @@map("users")
}

// ---------------------------------------------------------------------------
// Organization — multi-tenant workspace
// ---------------------------------------------------------------------------
model Organization {
  id            String    @id @default(uuid())
  name          String
  slug          String    @unique
  plan          Plan      @default(FREE)
  razorpaySubId String?
  planExpiresAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  members  OrgMember[]
  invites  OrgInvite[]
  testRuns TestRun[]

  @@map("organizations")
}

// ---------------------------------------------------------------------------
// OrgMember — join table with role
// ---------------------------------------------------------------------------
model OrgMember {
  id       String   @id @default(uuid())
  orgId    String
  userId   String
  role     OrgRole  @default(VIEWER)
  joinedAt DateTime @default(now())

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
  @@map("org_members")
}

// ---------------------------------------------------------------------------
// OrgInvite — token-based invite (copy-link, no SMTP required)
// ---------------------------------------------------------------------------
model OrgInvite {
  id         String    @id @default(uuid())
  orgId      String
  email      String
  role       OrgRole   @default(VIEWER)
  token      String    @unique
  createdBy  String
  acceptedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([token])
  @@map("org_invites")
}

// ---------------------------------------------------------------------------
// Test Run — the top-level attack session
// ---------------------------------------------------------------------------
model TestRun {
  id              String    @id @default(uuid())
  specUrl         String
  status          String    @default("PENDING") // PENDING | PARSING | GENERATING | ATTACKING | COMPLETED | FAILED
  totalEndpoints  Int       @default(0)
  totalAttacks    Int       @default(0)
  completedAttacks Int      @default(0)
  enqueuedAt      DateTime? // set once ALL attack jobs are enqueued; guards premature completion
  // Denormalized score, computed once when the run reaches a terminal state so
  // the history list doesn't have to load every log to re-derive it. Nullable:
  // in-progress runs and pre-migration rows fall back to on-the-fly scoring.
  overallScore    Int?
  scoreLabel      String?
  errorMessage    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  completedAt     DateTime?

  userId          String?
  user            User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId           String?
  org             Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  endpoints TargetEndpoint[]
  logs      AttackLog[]

  @@index([userId, createdAt])
  @@index([orgId, createdAt])
  @@map("test_runs")
}

// ---------------------------------------------------------------------------
// Webhook Event — idempotency ledger for Razorpay webhook deliveries
// ---------------------------------------------------------------------------
model WebhookEvent {
  id          String   @id @default(uuid())
  eventId     String   @unique // Razorpay x-razorpay-event-id
  event       String
  processedAt DateTime @default(now())

  @@map("webhook_events")
}

// ---------------------------------------------------------------------------
// Target Endpoint — parsed routes from the OpenAPI spec
// ---------------------------------------------------------------------------
model TargetEndpoint {
  id                String  @id @default(uuid())
  testRunId         String
  method            String  // GET | POST | PUT | DELETE | PATCH
  path              String
  operationId       String?
  requestBodySchema Json?   // raw JSON schema for the request body

  testRun TestRun     @relation(fields: [testRunId], references: [id], onDelete: Cascade)
  logs    AttackLog[]

  @@index([testRunId])
  @@map("target_endpoints")
}

// ---------------------------------------------------------------------------
// Verified Target — domain ownership proof before scanning
// ---------------------------------------------------------------------------
model VerifiedTarget {
  id         String    @id @default(uuid())
  userId     String
  domain     String
  token      String    @unique
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, domain])
  @@index([userId])
  @@map("verified_targets")
}

// ---------------------------------------------------------------------------
// Attack Log — individual payload execution results
// ---------------------------------------------------------------------------
model AttackLog {
  id              String   @id @default(uuid())
  testRunId       String
  endpointId      String
  method          String
  path            String
  payload         String   @db.Text
  statusCode      Int?
  latencyMs       Int?
  responseSnippet String?  @db.Text
  attackType      String   @default("UNKNOWN")
  error           String?
  createdAt       DateTime @default(now())

  testRun  TestRun        @relation(fields: [testRunId], references: [id], onDelete: Cascade)
  endpoint TargetEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([testRunId])
  @@index([endpointId])
  @@map("attack_logs")
}
