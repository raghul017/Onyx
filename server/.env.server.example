# ==============================================================================
# Render Deployment - Environment Variables
# ==============================================================================

# PORT: The port the Express server binds to (Render sets this automatically).
# You typically don't need to configure this manually on Render.
PORT=3000

# CLIENT_URL: The public domain where the React app is hosted (e.g. Vercel).
# This configures CORS so the backend accepts requests.
# Can be a single URL or comma-separated list.
# Example: https://my-onyx-app.vercel.app
CLIENT_URL=http://localhost:8080

# DATABASE_URL: The PostgreSQL connection string (Neon DB).
# Example: postgres://user:pass@ep-restless-bird.pooler.supavisor.com/db
DATABASE_URL=

# REDIS_HOST: The hostname of your Redis instance.
# Example: redis-12345.c123.us-east-1.cloud.redislabs.com
REDIS_HOST=127.0.0.1

# REDIS_PORT: The port for the Redis instance (usually 6379, 6380 for TLS).
REDIS_PORT=6379

# REDIS_PASSWORD: The password/auth token for Redis.
REDIS_PASSWORD=

# REDIS_TLS: Set to 'true' if the Redis host requires TLS (Upstash/Render managed Redis often do).
REDIS_TLS=

# JWT_SECRET: A strong randomized string for cryptographic JWT signing.
# Generate via: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
JWT_SECRET=onyx_fallback_secret_do_not_use_in_prod

# GEMINI_API_KEY: The Google AI Studio key for payload generation.
GEMINI_API_KEY=
