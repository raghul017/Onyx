# ==============================================================================
# Render Deployment - Environment Variables
# ==============================================================================

# PORT: The port the Express server binds to (Render sets this automatically).
# You typically don't need to configure this manually on Render.
PORT=3000

# CLIENT_URL: The public domain where the React app is hosted (e.g. Vercel).
# This configures CORS so the backend accepts requests.
# Can be a single URL or comma-separated list.
# Example: https://my-onyx-app.vercel.app
CLIENT_URL=http://localhost:8080

# DATABASE_URL: The PostgreSQL connection string (Neon DB).
# Example: postgres://user:pass@ep-restless-bird.pooler.supavisor.com/db
DATABASE_URL=

# REDIS_HOST: The hostname of your Redis instance.
# Example: redis-12345.c123.us-east-1.cloud.redislabs.com
REDIS_HOST=127.0.0.1

# REDIS_PORT: The port for the Redis instance (usually 6379, 6380 for TLS).
REDIS_PORT=6379

# REDIS_PASSWORD: The password/auth token for Redis.
REDIS_PASSWORD=

# REDIS_TLS: Set to 'true' if the Redis host requires TLS (Upstash/Render managed Redis often do).
REDIS_TLS=

# JWT_SECRET: A strong randomized string for cryptographic JWT signing.
# Generate via: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
JWT_SECRET=onyx_fallback_secret_do_not_use_in_prod

# SERVER_URL: The public base URL of THIS backend (no trailing slash). Used to
# build the OAuth redirect_uri. Local: http://localhost:3000  Prod: your Render URL.
SERVER_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# OAuth (Google + GitHub social sign-in). Leave blank to disable a provider —
# its button returns a clean "not configured" message instead of crashing.
# Register these redirect URIs with each provider:
#   Google: <SERVER_URL>/api/auth/google/callback
#   GitHub: <SERVER_URL>/api/auth/github/callback
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GEMINI_API_KEY: The Google AI Studio key for payload generation.
GEMINI_API_KEY=

# RAZORPAY_KEY_ID: Your Razorpay API key ID (from Razorpay Dashboard → Settings → API Keys).
RAZORPAY_KEY_ID=

# RAZORPAY_KEY_SECRET: Your Razorpay API key secret.
RAZORPAY_KEY_SECRET=

# RAZORPAY_WEBHOOK_SECRET: The webhook secret set in Razorpay Dashboard → Webhooks.
# Used to verify that incoming webhook requests genuinely originate from Razorpay.
RAZORPAY_WEBHOOK_SECRET=

# RAZORPAY_PRO_PLAN_ID: The Razorpay plan_id for the Pro subscription tier ($29/mo).
# Create plans in Razorpay Dashboard → Subscriptions → Plans.
RAZORPAY_PRO_PLAN_ID=

# RAZORPAY_TEAM_PLAN_ID: The Razorpay plan_id for the Team subscription tier ($99/mo).
RAZORPAY_TEAM_PLAN_ID=
